{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (CMake - w64devkit)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/NanquimoriEngine.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/raylib/w64devkit/bin;${env:PATH}"
                }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Sync Debug EXE to Workspace Build"
        },
        {
            "name": "Run (CMake - Release)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/NanquimoriEngine.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/raylib/w64devkit/bin;${env:PATH}"
                }
            ],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe",
            "preLaunchTask": "CMake: Sync Release EXE to Workspace Build"
        }
    ]
}
